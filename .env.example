# cypod-telemetry — copy to .env.local and adjust if your backend is not on :3000

# Where the Vite dev server forwards /api. Only used in development; in production the app and the
# API are expected to sit behind the same origin, which is why there is no absolute API URL here.
VITE_API_TARGET="http://localhost:3000"

# How often the fleet list re-asks the backend for each device's latest state, in milliseconds.
# The task asks for roughly five seconds.
VITE_TELEMETRY_POLL_INTERVAL_MS=5000
